```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
.venv/
venv/
env/
node_modules/

# Build artifacts
dist/
build/
target/

# Logs and temporary files
*.log
*.tmp
*.swp

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Cache directories
.mypy_cache/
.pytest_cache/
```